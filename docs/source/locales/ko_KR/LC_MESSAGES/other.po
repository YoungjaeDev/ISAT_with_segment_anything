msgstr "approx_polygon_disabled.png"

#: ../../source/other.rst:28
msgid "Applies after ``Contour Method``."
msgstr "``Contour Method`` 이후에 적용됩니다."

#: ../../source/other.rst:31
msgid "1.2 Use Bfloat16"
msgstr "1.2 Bfloat16 사용"

#: ../../source/other.rst:33
msgid "Run sam on bfloat16 for smaller GPU memory footprint."
msgstr "GPU 메모리 사용량을 줄이려면 bfloat16에서 sam을 실행하세요."

#: ../../source/other.rst:36
msgid "1.3 Use Video Segmentation"
msgstr "1.3 비디오 분할 사용"

#: ../../source/other.rst:38
msgid "Close video segmentation feature for smaller GPU memory footprint."
msgstr "더 작은 GPU 메모리 공간을 위한 비디오 분할 기능을 닫습니다."

#: ../../source/other.rst:41
msgid "1.4 Real Time Area"
msgstr "1.4 실시간 영역"

#: ../../source/other.rst:43
msgid ""
"Calculate the area in real time while editing the polygon. If false update "
"only when saving."
msgstr "폴리곤을 편집하는 동안 실시간으로 면적을 계산합니다. false인 경우 저장 시에만 업데이트됩니다."

#: ../../source/other.rst:-1
msgid "area.png"
msgstr "area.png"


msgstr "``ProjectName``/``PluginPackage``/``__init__.py``"

#: ../../source/plugin_development.rst:236
msgid ""
"Including information such as version, author, and package description."
msgstr "버전, 작성자, 패키지 설명 등의 정보가 포함됩니다."

#: ../../source/plugin_development.rst:244
msgid "``ProjectName``/``PluginPackage``/``main.py``"
msgstr "``ProjectName``/``PluginPackage``/``main.py``"

